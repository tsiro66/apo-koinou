---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { getLocaleFromUrl, localizedPath } from '../i18n/utils';

interface Props {
  contributor: CollectionEntry<'synteleistes'>;
}
const { contributor } = Astro.props;
const d = contributor.data;
const locale = getLocaleFromUrl(Astro.url);
const href = localizedPath(`/synteleistes/${contributor.id}`, locale);
---

<article class="group flex flex-col items-center text-center">
  <a href={href} class="block">
    {
      d.photo ? (
        <Image
          src={d.photo}
          alt={d.name}
          widths={[160, 320]}
          sizes="160px"
          width={320}
          height={320}
          class="h-40 w-40 rounded-full object-cover grayscale transition group-hover:grayscale-0"
        />
      ) : (
        <div class="flex h-40 w-40 items-center justify-center rounded-full bg-zinc-950/10 font-serif text-3xl text-zinc-950/40">
          {d.name.charAt(0)}
        </div>
      )
    }
  </a>
  <h3 class="mt-4 font-serif text-lg text-zinc-950">
    <a href={href} class="hover:text-zinc-950">{d.name}</a>
  </h3>
  {d.role && <p class="text-sm text-zinc-600">{d.role}</p>}
</article>