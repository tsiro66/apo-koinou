---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { getLocaleFromUrl, localizedPath } from '../i18n/utils';

interface Props {
  play: CollectionEntry<'parastaseis'>;
}
const { play } = Astro.props;
const d = play.data;
const locale = getLocaleFromUrl(Astro.url);
const href = localizedPath(`/parastaseis/${play.id}`, locale);
---

<article class="group overflow-hidden rounded-lg border border-zinc-950/10 bg-zinc-50 shadow-sm transition hover:shadow-md">
  <a href={href} class="block">
    {
      d.thumbnail ? (
        <Image
          src={d.thumbnail}
          alt={d.title}
          widths={[240, 480, 640]}
          sizes="(min-width:1024px) 33vw,(min-width:640px) 50vw,100vw"
          width={640}
          height={360}
          class="aspect-video w-full object-cover"
        />
      ) : (
        <div class="flex aspect-video w-full items-center justify-center bg-zinc-950/5 font-serif text-2xl text-zinc-950/40">
          {d.title}
        </div>
      )
    }
    <div class="p-4">
      <h3 class="font-serif text-xl text-zinc-950 group-hover:text-zinc-950">
        {d.title}
      </h3>
      <p class="mt-1 text-sm text-zinc-600">{d.year}{d.director ? ` — ${d.director}` : ''}</p>
      {d.summary && (
        <p class="mt-3 line-clamp-2 text-sm text-zinc-950/70">{d.summary}</p>
      )}
    </div>
  </a>
</article>