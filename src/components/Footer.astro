---
import { SITE, NAV_LINKS, BRAND } from '../consts';
import { Image } from 'astro:assets';
import { getLocaleFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import logo from '../assets/logos/logo.jpg';
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const brand = BRAND[locale];
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-zinc-950/10 bg-zinc-950 text-zinc-50">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:grid-cols-3">
    <div>
      <Image
        src={logo}
        alt={brand.title}
        widths={[96, 144, 192]}
        sizes="192px"
        height={64}
        class="h-30 w-auto"
      />
      <p class="mt-3 text-sm text-zinc-50/70">{brand.tagline}</p>
    </div>

    <nav aria-label={t('footer.nav_aria')}>
      <ul class="grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a href={localizedPath(link.href, locale)} class="text-zinc-50/80 hover:text-gold">
                {t(link.labelKey)}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="text-sm text-zinc-50/70">
      <a href={`mailto:${SITE.email}`} class="hover:text-gold">
        {SITE.email}
      </a>
      <p class="mt-3">© {year} {brand.title}. {t('footer.rights')}</p>
    </div>
  </div>
</footer>