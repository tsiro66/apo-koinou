---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getLocaleFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  images: ImageMetadata[];
  alt: string;
}
const { images, alt } = Astro.props;
const t = useTranslations(getLocaleFromUrl(Astro.url));
const photoWord = t('common.photo');
---

{
  images.length > 0 && (
    <ul class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
      {images.map((src, i) => (
        <li>
          <a
            href={src.src}
            target="_blank"
            class="block overflow-hidden rounded-md border border-zinc-950/10"
          >
            <Image
              src={src}
              alt={`${alt} — ${photoWord} ${i + 1}`}
              widths={[240, 480, 640]}
              sizes="(min-width:1024px) 25vw,(min-width:640px) 33vw,50vw"
              width={480}
              height={480}
              class="aspect-square w-full object-cover transition hover:scale-105"
            />
          </a>
        </li>
      ))}
    </ul>
  )
}