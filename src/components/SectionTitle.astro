---
interface Props {
  title: string;
  eyebrow?: string;
  as?: 'h1' | 'h2' | 'h3';
  align?: 'left' | 'center';
}
const { title, eyebrow, as: Tag = 'h2', align = 'left' } = Astro.props;
const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
---

<div class={`max-w-3xl ${alignClass}`}>
  {eyebrow && (
    <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-gold">
      {eyebrow}
    </p>
  )}
  <Tag class="font-serif text-3xl leading-tight text-ink sm:text-4xl">
    {title}
  </Tag>
</div>