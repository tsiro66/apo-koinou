---
import { getCollection } from 'astro:content';
import ContributorDetail from '../../sections/ContributorDetail.astro';

export async function getStaticPaths() {
  const contributors = await getCollection('synteleistes');
  return contributors.map((c) => ({
    params: { slug: c.id },
    props: { contributor: c },
  }));
}

const { contributor } = Astro.props;
---

<ContributorDetail contributor={contributor} />