---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { getLocaleFromUrl, useTranslations, localizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<BaseLayout title={t('page.404.title')} canonicalPath="/404">
  <section class="mx-auto max-w-6xl py-20 text-center">
    <p class="font-serif text-7xl text-zinc-950">{t('page.404.code')}</p>
    <h1 class="mt-4 font-serif text-3xl text-zinc-950">{t('page.404.heading')}</h1>
    <p class="mt-4 text-zinc-600">{t('page.404.body')}</p>
    <div class="mt-8">
      <CTA href={localizedPath('/', locale)} label={t('common.back_home')} />
    </div>
  </section>
</BaseLayout>