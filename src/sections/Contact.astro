---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../consts';
import { getLocaleFromUrl, useTranslations, localizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<BaseLayout title={t('page.epikoinonia.title')} canonicalPath="/epikoinonia">
  <div class="mx-auto max-w-6xl">
    <Breadcrumbs crumbs={[{ label: t('nav.home'), href: localizedPath('/', locale) }, { label: t('page.epikoinonia.title') }]} />
    <div class="mt-6">
      <SectionTitle eyebrow={t('page.epikoinonia.eyebrow')} title={t('page.epikoinonia.heading')} />
    </div>
    <div class="mt-6 space-y-4 text-lg text-ink/80">
      <p>{t('page.epikoinonia.body')}</p>
      <p>
        <a href={`mailto:${SITE.email}`} class="font-semibold text-curtain hover:underline">
          {SITE.email}
        </a>
      </p>
    </div>
  </div>
</BaseLayout>